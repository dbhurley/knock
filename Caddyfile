# Knock - Caddy Reverse Proxy Configuration
# Automatic HTTPS via Let's Encrypt for all domains

# Global options
{
	email admin@askknock.com
	acme_ca https://acme-v02.api.letsencrypt.org/directory
}

# Public marketing site
askknock.com {
	root * /srv/public

	# Protect assessment tool with basic auth (Dan only)
	@assess path /assess.html
	basic_auth @assess {
		# Password hash generated via: caddy hash-password --plaintext <password>
		dan $2a$14$XsY4m.h2zd8LIGtn2boLJO35cuqjNxxxy0JuFIHR.P26rd8v6iQeO
	}

	file_server

	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		X-XSS-Protection "1; mode=block"
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		-Server
	}

	handle_errors {
		respond "{err.status_code} {err.status_text}"
	}

	log {
		output file /var/log/caddy/askknock.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}

# OpenClaw Gateway dashboard (token-protected)
janet.askknock.com {
	reverse_proxy knock-openclaw:3000 {
		header_up X-Real-IP {remote_host}
		transport http {
			keepalive 30s
			keepalive_idle_conns 10
		}
	}

	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		-Server
	}

	log {
		output file /var/log/caddy/janet.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}

# REST API
api.askknock.com {
	reverse_proxy knock-api:4000 {
		header_up X-Real-IP {remote_host}
		transport http {
			keepalive 30s
			keepalive_idle_conns 20
		}
		health_uri /health
		health_interval 30s
		health_timeout 5s
	}

	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		Access-Control-Allow-Origin *
		Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
		Access-Control-Allow-Headers "Authorization, Content-Type"
		-Server
	}

	@options method OPTIONS
	respond @options 204

	# Rate limiting placeholder - Caddy rate_limit module required
	# rate_limit {remote.ip} 100r/m

	log {
		output file /var/log/caddy/api.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}

# Grafana monitoring (internal access)
grafana.askknock.com {
	reverse_proxy knock-grafana:3001 {
		header_up X-Real-IP {remote_host}
	}

	header {
		X-Content-Type-Options nosniff
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		-Server
	}

	log {
		output file /var/log/caddy/grafana.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}
